# Build artifacts (regenerated by deploy.bat every time)
lambda/*.zip
*.zip

# Local test outputs (not needed in the repo)
response.json
response_*.json

# Python
__pycache__/
*.pyc
*.pyo

# AWS credentials -- should NEVER be committed
.aws/
*.pem
credentials

# Real config files -- contain your actual AWS account ID / ARNs.
# Keep these local only. Sanitized .example versions are committed instead.
trust-policy.json
permissions-policy.json
environment.json
targets.json

# OS junk files
.DS_Store
Thumbs.db

# Editor files
.vscode/
*.swp
